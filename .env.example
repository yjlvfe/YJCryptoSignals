# CryptoSignal Bot — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم الفعلية
# cp .env.example .env

# ═══════════════ AI API Keys ═══════════════
# Multi-Provider AI — configure your AI provider credentials here
# Set your API keys and endpoint URL below
# CRYPTOSIGNAL_AI_KEYS=your-key-here
# CRYPTOSIGNAL_AI_BASE=https://your-provider-url/v1
# CRYPTOSIGNAL_AI_MODEL=your-model-name
# CRYPTOSIGNAL_AI_MAX_TOKENS=900
# CRYPTOSIGNAL_AI_TIMEOUT=45

# ═══════════════ Telegram Bot ═══════════════
# بوت Telegram (يُقرأ من الكود حالياً)
# TELEGRAM_BOT_TOKEN=your-token-here

# ═══════════════ Exchange API Keys (اختياري) ═══════════════
# MEXC_API_KEY=
# MEXC_API_SECRET=
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
